# --- PyInstaller ---
# Ignore the large folders generated when building the .exe
build/
dist/
*.spec

# --- Python ---
# Ignore compiled byte-code files and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Virtual Environments ---
# Ignore local virtual environments (devs should make their own)
venv/
.venv/
env/
.env/

# --- IDEs and Editors ---
# Ignore local workspace settings for VS Code, PyCharm, etc.
.vscode/
.idea/
*.swp
*.swo

# --- OS Generated Files ---
# Ignore hidden system files generated by Windows or Mac
.DS_Store
Thumbs.db
Desktop.ini